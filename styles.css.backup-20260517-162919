  text-shadow: 0 0 10px rgba(255, 104, 25, 0.55);
}

#detail-screen[class*="type-fire"] .tag-chip,
#detail-screen[class*="type-fire"] .evolution-type-pills span {
  color: #ffe0b7;
  border-color: rgba(255, 128, 31, 0.52);
  background: rgba(83, 24, 7, 0.62);
}

