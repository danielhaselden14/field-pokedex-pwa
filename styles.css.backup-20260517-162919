#detail-screen.type-electric {
  position: relative;
  overflow: hidden;
  padding: 14px;
  border-radius: 22px;
  color: #eaf8ff;
  background:
    radial-gradient(circle at 82% 18%, rgba(255, 231, 45, 0.32), transparent 19%),
    radial-gradient(circle at 78% 18%, rgba(0, 190, 255, 0.24), transparent 26%),
