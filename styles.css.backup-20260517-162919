    linear-gradient(145deg, rgba(4, 24, 42, 0.96), rgba(1, 9, 18, 0.96));
  border: 1px solid rgba(0, 190, 255, 0.42);
  border-radius: 14px;
  box-shadow:
    0 0 18px rgba(0, 190, 255, 0.16),
    inset 0 0 20px rgba(0, 190, 255, 0.08);
}

#detail-screen.type-electric .entry-card::before {
  display: block;
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.42;
  background:
    linear-gradient(120deg, rgba(255, 231, 45, 0.14), transparent 26%),
