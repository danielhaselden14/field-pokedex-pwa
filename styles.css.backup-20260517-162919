  background: rgba(255, 226, 197, 0.12);
  border: 1px solid rgba(255, 128, 31, 0.24);
}

#detail-screen[class*="type-fire"] .stat-bar-fill {
  background:
    linear-gradient(90deg, #ff3d1a, #ff8a24, #ffc15a);
