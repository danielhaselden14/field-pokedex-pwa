}

#detail-screen.type-electric::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  opacity: 0.52;
  background:
    linear-gradient(115deg, transparent 0 18%, rgba(0, 190, 255, 0.42) 19%, transparent 21%),
