* {
  box-sizing: border-box;
}

:root {
  --bg: #0f1f16;
  --panel: #173522;
  --panel-light: #224b31;
  --text: #f3f7ef;
  --muted: #b8c9b7;
  --accent: #8fd694;
  --border: rgba(255, 255, 255, 0.12);
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: var(--bg);
  color: var(--text);
}

button {
  font: inherit;
}

.app-shell {
  min-height: 100vh;
  width: 100%;
}

.app-header {
  padding: 24px 18px 12px;
  background: linear-gradient(180deg, #1f3d2b, #0f1f16);
}

.eyebrow {
  margin: 0 0 6px;
  color: var(--accent);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 0;
  font-size: 2rem;
}

.category-nav {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding: 12px 14px;
  background: #0f1f16;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-button {
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 10px 14px;
  color: var(--text);
  background: var(--panel);
  white-space: nowrap;
}

.nav-button.active {
  background: var(--accent);
  color: #102015;
  font-weight: 700;
}

.main-content {
  padding: 16px;
  max-width: 900px;
  margin: 0 auto;
}

.hero-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 20px;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
}

.hero-card h2 {
  margin-bottom: 10px;
  font-size: 1.55rem;
}

.hero-card p {
  color: var(--muted);
  line-height: 1.5;
}

.section-header {
  margin: 24px 2px 12px;
}

.section-header h2 {
  margin-bottom: 4px;
}

.section-header p {
  margin-bottom: 0;
  color: var(--muted);
}

.card-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

.entry-card {
  background: var(--panel-light);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 18px;
}

.entry-card h3 {
  margin-bottom: 8px;
}

.entry-card p {
  color: var(--muted);
  line-height: 1.45;
  margin-bottom: 0;
}

@media (min-width: 700px) {
  .card-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .app-header {
    padding-left: 28px;
    padding-right: 28px;
  }

  .main-content {
    padding: 24px;
  }
}
.screen {
  display: none;
}

.screen.active-screen {
  display: block;
}

.entry-meta {
  color: var(--accent);
  font-size: 0.85rem;
  font-weight: 700;
}

.survival-use {
  margin-top: 12px;
}

.field-note {
  margin-top: 12px;
  font-style: italic;
}

.search-panel {
  margin: 18px 0 8px;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 14px;
}

.search-panel label {
  display: block;
  margin-bottom: 8px;
  color: var(--accent);
  font-size: 0.85rem;
  font-weight: 700;
}

.search-panel input {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 13px 14px;
  background: #08140e;
  color: var(--text);
  font: inherit;
}

.search-panel input::placeholder {
  color: var(--muted);
}

.hidden {
  display: none !important;
}

.back-button {
  margin-bottom: 14px;
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 10px 14px;
  background: var(--panel);
  color: var(--text);
}

.detail-card {
  margin-bottom: 14px;
}

.clickable-card {
  cursor: pointer;
}

.clickable-card:active {
  transform: scale(0.98);
}

#detail-screen {
  position: relative;
  overflow: hidden;
}

#detail-screen > * {
  position: relative;
  z-index: 2;
}

#detail-screen.type-electric::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  opacity: 0.28;
  background:
    linear-gradient(115deg, transparent 0 42%, rgba(255, 238, 88, 0.95) 43%, transparent 46%),
    linear-gradient(245deg, transparent 0 55%, rgba(255, 255, 255, 0.8) 56%, transparent 59%),
    radial-gradient(circle at 70% 20%, rgba(255, 238, 88, 0.45), transparent 28%);
  animation: electric-screen-flash 1.6s infinite;
}

#detail-screen.type-electric .detail-card {
  box-shadow: 0 0 22px rgba(255, 238, 88, 0.45);
}

@keyframes electric-screen-flash {
  0%, 100% {
    opacity: 0.08;
    transform: translateX(-8px);
  }

  12% {
    opacity: 0.35;
    transform: translateX(4px);
  }

  18% {
    opacity: 0.12;
    transform: translateX(-2px);
  }

  32% {
    opacity: 0.45;
    transform: translateX(7px);
  }

  38% {
    opacity: 0.15;
    transform: translateX(0);
  }
}

/* ===== ELECTRIC HUD THEME v19 ===== */

:root {
  --hud-bg: #020812;
  --hud-panel: rgba(3, 18, 32, 0.92);
  --hud-panel-soft: rgba(5, 31, 51, 0.72);
  --hud-blue: #24c8ff;
  --hud-blue-soft: rgba(36, 200, 255, 0.35);
  --hud-yellow: #ffe94a;
  --hud-yellow-soft: rgba(255, 233, 74, 0.35);
  --hud-green: #67ff7a;
  --hud-text: #e8f7ff;
  --hud-muted: #8fb6c9;
  --hud-danger: #ffcf33;
}

body {
  min-height: 100vh;
  color: var(--hud-text);
  background:
    radial-gradient(circle at 20% 0%, rgba(255, 233, 74, 0.14), transparent 28%),
    radial-gradient(circle at 80% 10%, rgba(36, 200, 255, 0.16), transparent 30%),
    linear-gradient(180deg, #020812 0%, #04111d 48%, #020812 100%);
  background-attachment: fixed;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.28;
  background-image:
    linear-gradient(rgba(36, 200, 255, 0.09) 1px, transparent 1px),
    linear-gradient(90deg, rgba(36, 200, 255, 0.09) 1px, transparent 1px);
  background-size: 32px 32px;
  z-index: 0;
}

body::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  opacity: 0.75;
  background:
    linear-gradient(115deg, transparent 0 58%, rgba(255, 233, 74, 0.16) 59%, transparent 61%),
    linear-gradient(245deg, transparent 0 70%, rgba(36, 200, 255, 0.14) 71%, transparent 73%);
  animation: hudEnergyDrift 6s infinite linear;
}

.app-shell {
  position: relative;
  z-index: 2;
  max-width: 1180px;
  margin: 0 auto;
  padding: 18px;
}

.app-header {
  border: 1px solid var(--hud-blue-soft);
  background:
    linear-gradient(135deg, rgba(4, 20, 36, 0.95), rgba(2, 8, 18, 0.95)),
    radial-gradient(circle at 15% 40%, rgba(255, 233, 74, 0.18), transparent 24%);
  box-shadow:
    0 0 24px rgba(36, 200, 255, 0.2),
    inset 0 0 24px rgba(36, 200, 255, 0.08);
  border-radius: 18px;
  padding: 22px;
  margin-bottom: 14px;
}

.app-header h1 {
  color: var(--hud-text);
  letter-spacing: 1px;
  text-shadow:
    0 0 12px rgba(255, 233, 74, 0.55),
    0 0 22px rgba(36, 200, 255, 0.35);
}

.eyebrow {
  color: var(--hud-blue);
  letter-spacing: 2px;
  text-transform: uppercase;
}

.category-nav {
  gap: 10px;
  padding: 10px 0 16px;
}

.nav-button {
  color: var(--hud-text);
  background: linear-gradient(180deg, rgba(3, 25, 46, 0.95), rgba(1, 11, 22, 0.95));
  border: 1px solid var(--hud-blue-soft);
  border-radius: 6px;
  box-shadow:
    inset 0 0 14px rgba(36, 200, 255, 0.12),
    0 0 10px rgba(36, 200, 255, 0.08);
  clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.nav-button.active,
.nav-button:hover {
  color: #fff6a6;
  border-color: var(--hud-yellow);
  background:
    linear-gradient(180deg, rgba(75, 62, 6, 0.95), rgba(18, 15, 2, 0.98));
  box-shadow:
    0 0 18px rgba(255, 233, 74, 0.55),
    inset 0 0 18px rgba(255, 233, 74, 0.18);
}

.hero-card,
.entry-card,
.search-panel,
.section-header {
  background:
    linear-gradient(145deg, rgba(4, 19, 34, 0.96), rgba(1, 9, 18, 0.96));
  border: 1px solid var(--hud-blue-soft);
  box-shadow:
    0 0 18px rgba(36, 200, 255, 0.12),
    inset 0 0 24px rgba(36, 200, 255, 0.06);
}

.hero-card {
  border-color: var(--hud-yellow-soft);
  box-shadow:
    0 0 26px rgba(255, 233, 74, 0.2),
    inset 0 0 32px rgba(255, 233, 74, 0.06);
}

.hero-card h2,
.section-header h2,
.entry-card h3 {
  color: var(--hud-yellow);
  text-shadow: 0 0 12px rgba(255, 233, 74, 0.35);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.entry-card {
  position: relative;
  overflow: hidden;
}

.entry-card::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.35;
  background:
    linear-gradient(120deg, rgba(255, 233, 74, 0.12), transparent 28%),
    linear-gradient(300deg, rgba(36, 200, 255, 0.12), transparent 32%);
}

.entry-card > * {
  position: relative;
  z-index: 2;
}

.clickable-card {
  cursor: pointer;
  transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
}

.clickable-card:hover {
  transform: translateY(-3px);
  border-color: var(--hud-yellow);
  box-shadow:
    0 0 24px rgba(255, 233, 74, 0.28),
    inset 0 0 22px rgba(255, 233, 74, 0.08);
}

.search-panel input {
  color: var(--hud-text);
  background: rgba(0, 8, 16, 0.92);
  border: 1px solid var(--hud-blue-soft);
  box-shadow: inset 0 0 14px rgba(36, 200, 255, 0.12);
}

.search-panel input:focus {
  outline: none;
  border-color: var(--hud-yellow);
  box-shadow:
    0 0 16px rgba(255, 233, 74, 0.28),
    inset 0 0 14px rgba(36, 200, 255, 0.14);
}

.back-button {
  color: var(--hud-text);
  background: rgba(3, 20, 35, 0.95);
  border: 1px solid var(--hud-blue-soft);
  box-shadow: 0 0 12px rgba(36, 200, 255, 0.18);
}

.back-button:hover {
  border-color: var(--hud-yellow);
  box-shadow: 0 0 18px rgba(255, 233, 74, 0.28);
}

.warning-card {
  border-color: var(--hud-yellow-soft);
}

#detail-screen.type-electric {
  background:
    radial-gradient(circle at 78% 14%, rgba(255, 233, 74, 0.24), transparent 24%),
    radial-gradient(circle at 25% 70%, rgba(36, 200, 255, 0.16), transparent 24%);
  border-radius: 18px;
}

#detail-screen.type-electric::before {
  opacity: 0.42;
  background:
    linear-gradient(115deg, transparent 0 38%, rgba(255, 233, 74, 0.92) 39%, transparent 42%),
    linear-gradient(245deg, transparent 0 57%, rgba(36, 200, 255, 0.7) 58%, transparent 61%),
    linear-gradient(95deg, transparent 0 72%, rgba(255, 255, 255, 0.6) 73%, transparent 75%),
    radial-gradient(circle at 70% 20%, rgba(255, 233, 74, 0.45), transparent 25%);
  animation: electric-screen-flash 1.25s infinite;
}

@keyframes hudEnergyDrift {
  0% {
    transform: translateX(-8px);
    opacity: 0.45;
  }

  50% {
    transform: translateX(8px);
    opacity: 0.8;
  }

  100% {
    transform: translateX(-8px);
    opacity: 0.45;
  }
}

