}

#detail-screen.type-electric .entry-card h3 {
  color: #24c8ff;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-shadow: 0 0 10px rgba(0, 190, 255, 0.5);
}

#detail-screen.type-electric .warning-card {
  border-color: rgba(255, 231, 45, 0.7);
  box-shadow:
    0 0 22px rgba(255, 231, 45, 0.22),
    inset 0 0 18px rgba(255, 231, 45, 0.08);
}

#detail-screen.type-electric .warning-card h3 {
  color: #ffe72d;
  text-shadow: 0 0 12px rgba(255, 231, 45, 0.5);
}

@keyframes electricHudFlash {
  0%, 100% {
    opacity: 0.24;
    transform: translateX(-10px);
  }

  12% {
    opacity: 0.64;
    transform: translateX(5px);
  }

  18% {
    opacity: 0.28;
    transform: translateX(-3px);
  }

  34% {
    opacity: 0.72;
    transform: translateX(8px);
  }

  42% {
    opacity: 0.3;
