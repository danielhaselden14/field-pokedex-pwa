    0 0 12px rgba(255, 100, 24, 0.48),
    0 0 22px rgba(255, 55, 15, 0.22);
}

body[class*="entry-type-fire"] .nav-button.active,
body[class*="entry-type-fire"] .nav-button:hover {
  color: #ffb14a !important;
  text-shadow: 0 0 12px rgba(255, 100, 24, 0.65);
}

body[class*="entry-type-fire"] .nav-button.active::after {
  background: #ff7b2a !important;
  box-shadow: 0 0 14px rgba(255, 92, 18, 0.65);
}

@keyframes fireHeatDrift {
  0% {
    transform: translate3d(-10px, 0, 0);
    opacity: 0.22;
  }
  50% {
    transform: translate3d(10px, -8px, 0);
    opacity: 0.40;
  }
  100% {
    transform: translate3d(-10px, 0, 0);
    opacity: 0.22;
  }
}

@keyframes fireCorePulse {
  0%, 100% {
    transform: scale(1);
    filter: brightness(1);
  }
  50% {
    transform: scale(1.04);
    filter: brightness(1.24);
  }
}

@media (max-width: 700px) {
  #detail-screen[class*="type-fire"] .hero-card::after {
    width: 62px;
    height: 62px;
    right: 14px;
    top: 14px;
    font-size: 32px;
    border-radius: 18px;
  }

  #detail-screen[class*="type-fire"] .hero-card h2,
  #detail-screen[class*="type-fire"] #detail-name {
    max-width: 76%;
    font-size: clamp(2rem, 11vw, 3.2rem);
  }

  #detail-screen[class*="type-fire"] .evolution-mainline {
    gap: 0.65rem;
  }

  #detail-screen[class*="type-fire"] .evolution-family-node {
    min-width: 120px;
  }
}

